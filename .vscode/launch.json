{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask App",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "console": "integratedTerminal",
            "jinja": true,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Running on (http://\\S+)",
                "uriFormat": "%s"
            }
        }
    ]
}
